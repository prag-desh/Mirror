:root {
  --bg: #080810;
  --glass-bg: rgba(255, 255, 255, 0.04);
  --glass-border: rgba(255, 255, 255, 0.07);
  --text: #f4f4f8;
  --muted: rgba(255, 255, 255, 0.45);
  --gradient-start: #8b5cf6;
  --gradient-end: #ec4899;
  --gradient: linear-gradient(135deg, var(--gradient-start), var(--gradient-end));
  --radius-card: 18px;
  --shadow-soft: 0 24px 80px rgba(0, 0, 0, 0.45);
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  font-family: "Inter", system-ui, -apple-system, sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
}

#root {
  position: relative;
  z-index: 1;
  min-height: 100vh;
}

/* Animated background orbs */
.bg-orbs {
  position: fixed;
  inset: 0;
  z-index: 0;
  overflow: hidden;
  pointer-events: none;
}

.orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(90px);
  opacity: 0.5;
  animation: float-orb 22s ease-in-out infinite;
}

.orb-1 {
  width: min(480px, 90vw);
  height: min(480px, 90vw);
  background: var(--atm-orb1, rgba(139, 92, 246, 0.9));
  top: -12%;
  left: -8%;
}

.orb-2 {
  width: min(420px, 85vw);
  height: min(420px, 85vw);
  background: var(--atm-orb2, rgba(236, 72, 153, 0.85));
  top: 35%;
  right: -12%;
  animation-delay: -7s;
}

.orb-3 {
  width: min(360px, 75vw);
  height: min(360px, 75vw);
  background: radial-gradient(
    circle,
    rgba(167, 139, 250, 0.75) 0%,
    rgba(244, 114, 182, 0.5) 45%,
    transparent 70%
  );
  bottom: -8%;
  left: 25%;
  animation-delay: -14s;
}

@keyframes float-orb {
  0%,
  100% {
    transform: translate(0, 0) scale(1);
  }
  33% {
    transform: translate(8%, -6%) scale(1.08);
  }
  66% {
    transform: translate(-6%, 5%) scale(0.92);
  }
}

a {
  color: inherit;
  text-decoration: none;
}

button,
textarea {
  font: inherit;
}

.gradient-text {
  background: var(--gradient);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  color: transparent;
}

/* Glass card base */
.input-panel,
.result-card,
.share-card,
.disclaimer-card,
.safety-banner {
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  background: var(--atm-card-bg, rgba(255, 255, 255, 0.04));
  border: 1px solid var(--glass-border);
  box-shadow: var(--shadow-soft);
}

.app-shell {
  width: min(100%, 1120px);
  margin: 0 auto;
  padding: 24px 16px 80px;
}

.topbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0 28px;
}

.brand {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  font-weight: 700;
  font-size: 1.05rem;
}

.brand-name {
  background: var(--gradient);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}

.brand-icon {
  width: 40px;
  height: 40px;
  border-radius: 14px;
  display: grid;
  place-items: center;
  background: var(--gradient);
  color: #fff;
  box-shadow: 0 8px 32px rgba(139, 92, 246, 0.35);
}

.topnav {
  display: flex;
  align-items: center;
  gap: 12px;
}

.ghost-link {
  color: var(--muted);
  font-size: 0.875rem;
  font-weight: 500;
  padding: 8px 14px;
  border-radius: 999px;
  border: 1px solid transparent;
  transition: color 0.2s, border-color 0.2s, background 0.2s;
}

.ghost-link:hover {
  color: var(--text);
  border-color: var(--glass-border);
  background: rgba(255, 255, 255, 0.04);
}

.hero-section {
  text-align: center;
  max-width: 640px;
  margin: 0 auto 40px;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  margin: 0 0 20px;
  padding: 8px 16px 8px 12px;
  border-radius: 999px;
  border: 1px solid var(--glass-border);
  background: rgba(255, 255, 255, 0.04);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--muted);
}

.hero-badge-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--gradient);
  box-shadow: 0 0 12px rgba(236, 72, 153, 0.65);
  animation: pulse-dot 1.6s ease-in-out infinite;
}

@keyframes pulse-dot {
  0%,
  100% {
    transform: scale(1);
    opacity: 1;
  }
  50% {
    transform: scale(1.25);
    opacity: 0.75;
  }
}

.hero-title {
  font-size: clamp(28px, 5vw, 38px);
  font-weight: 800;
  line-height: 1.15;
  letter-spacing: -0.02em;
  margin: 0 0 18px;
}

.hero-subtitle {
  color: var(--muted);
  font-size: 1rem;
  line-height: 1.75;
  margin: 0 auto;
  max-width: 560px;
  font-weight: 400;
}

.input-panel {
  max-width: 860px;
  margin: 0 auto;
  border-radius: var(--radius-card);
  padding: 24px;
}

.panel-head {
  display: flex;
  gap: 14px;
  align-items: flex-start;
  margin-bottom: 18px;
}

.panel-icon {
  width: 44px;
  height: 44px;
  border-radius: 14px;
  display: grid;
  place-items: center;
  background: rgba(139, 92, 246, 0.2);
  color: #ddd6fe;
  flex-shrink: 0;
  border: 1px solid rgba(139, 92, 246, 0.25);
}

.panel-head h2,
.result-card h2,
.share-card h2 {
  margin: 0;
  font-weight: 700;
  font-size: 1.25rem;
}

.panel-head p,
.confidence-note,
.disclaimer-card p {
  color: var(--muted);
  font-size: 0.9375rem;
  line-height: 1.6;
}

.card-label,
.share-pattern {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--muted);
  margin: 0 0 10px;
}

.emotion-input {
  width: 100%;
  border: 1px solid var(--glass-border);
  background: rgba(0, 0, 0, 0.35);
  color: var(--text);
  border-radius: 14px;
  padding: 18px;
  outline: none;
  resize: vertical;
  min-height: 170px;
  line-height: 1.7;
  transition: border-color 0.2s, box-shadow 0.2s;
}

.emotion-input::placeholder {
  color: rgba(255, 255, 255, 0.28);
}

.emotion-input:focus {
  border-color: var(--gradient-start);
  box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.2);
}

.emotion-input--glow-mid:not(:focus) {
  box-shadow: 0 0 0 1px rgba(139, 92, 246, 0.3);
}

.emotion-input--glow-mid:focus {
  box-shadow:
    0 0 0 1px rgba(139, 92, 246, 0.3),
    0 0 0 3px rgba(139, 92, 246, 0.2);
}

.emotion-input--glow-strong:not(:focus) {
  box-shadow:
    0 0 0 2px rgba(139, 92, 246, 0.6),
    0 0 20px rgba(139, 92, 246, 0.15);
}

.emotion-input--glow-strong:focus {
  box-shadow:
    0 0 0 2px rgba(139, 92, 246, 0.6),
    0 0 20px rgba(139, 92, 246, 0.15),
    0 0 0 3px rgba(139, 92, 246, 0.2);
}

.input-word-hint {
  margin: 10px 0 0;
  font-size: 0.8125rem;
  font-weight: 500;
  line-height: 1.4;
  min-height: 1.25em;
}

.input-word-hint--muted {
  color: var(--muted);
}

.input-word-hint--purple {
  color: var(--gradient-start);
}

.panel-actions {
  margin-top: 20px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  align-items: stretch;
}

.panel-tip {
  color: var(--muted);
  margin: 0;
  font-size: 0.875rem;
  line-height: 1.6;
  text-align: center;
}

.primary-btn {
  width: 100%;
  border: none;
  background: var(--gradient);
  color: #fff;
  padding: 16px 20px;
  border-radius: 14px;
  font-weight: 800;
  font-size: 0.9375rem;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  cursor: pointer;
  box-shadow: 0 12px 40px rgba(139, 92, 246, 0.35);
  transition: transform 0.15s ease, box-shadow 0.2s ease, opacity 0.2s;
}

.primary-btn:hover:not(:disabled) {
  transform: translateY(-1px);
  box-shadow: 0 16px 48px rgba(236, 72, 153, 0.3);
}

.primary-btn:disabled {
  opacity: 0.65;
  cursor: not-allowed;
  transform: none;
}

.loading-box {
  margin-top: 20px;
  padding: 18px 20px;
  border-radius: var(--radius-card);
  border: 1px solid var(--glass-border);
  background: rgba(0, 0, 0, 0.25);
  display: flex;
  align-items: center;
  gap: 16px;
}

.loading-box p {
  margin: 0;
  color: var(--muted);
  font-size: 0.875rem;
}

.loading-phrase {
  animation: loadingPhraseIn 0.45s ease-out both;
}

@keyframes loadingPhraseIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.loading-breather {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: var(--gradient);
  box-shadow: 0 0 20px rgba(139, 92, 246, 0.3);
  animation: breathe 3s ease-in-out infinite;
  flex-shrink: 0;
}

@keyframes breathe {
  0%, 100% {
    transform: scale(1.0);
  }
  50% {
    transform: scale(1.15);
  }
}

@keyframes loading-bounce {
  0%,
  80%,
  100% {
    transform: translateY(0) scale(1);
    opacity: 0.5;
  }
  40% {
    transform: translateY(-8px) scale(1.05);
    opacity: 1;
  }
}

.results-page-head {
  max-width: 820px;
  margin: 0 auto 28px;
  text-align: center;
}

.results-page-title {
  margin: 0;
  font-size: clamp(22px, 4vw, 28px);
  font-weight: 800;
  letter-spacing: -0.02em;
  line-height: 1.2;
}

.app-shell--results .results-page-head {
  padding-top: 4px;
}

@keyframes cardReveal {
  from {
    opacity: 0;
    transform: translateY(24px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.card-reveal {
  opacity: 0;
  animation: cardReveal 400ms ease-out forwards;
}

.results-stack {
  max-width: 820px;
  margin: 0 auto;
  display: grid;
  gap: 16px;
}

.result-card,
.share-card,
.disclaimer-card {
  border-radius: var(--radius-card);
  padding: 22px;
}

.pattern-card {
  background:
    linear-gradient(145deg, rgba(139, 92, 246, 0.22) 0%, rgba(236, 72, 153, 0.12) 50%, rgba(255, 255, 255, 0.04) 100%),
    var(--glass-bg);
  border-color: rgba(167, 139, 250, 0.2);
}

.pattern-card .card-label {
  color: rgba(221, 214, 254, 0.65);
}

.pattern-card .pattern-title-typewriter {
  font-size: clamp(1.35rem, 3.5vw, 1.75rem);
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 0.1em;
  min-height: 1.2em;
}

.pattern-title-typewriter__text {
  background: var(--gradient);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}

.pattern-title-typewriter__cursor {
  -webkit-text-fill-color: #e9d5ff;
  color: #e9d5ff;
  font-weight: 300;
  animation: cursorBlink 0.95s step-end infinite;
}

@keyframes cursorBlink {
  0%,
  50% {
    opacity: 1;
  }
  51%,
  100% {
    opacity: 0;
  }
}

.confidence-note {
  margin-top: 8px;
  margin-bottom: 22px;
  line-height: 1.6;
}

.block-title {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--muted);
  margin: 0 0 10px;
}

.content-block p {
  margin: 0;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.82);
}

.message-box {
  font-size: 1.05rem;
  line-height: 1.8;
  padding: 18px;
  border-radius: 14px;
  background: rgba(0, 0, 0, 0.2);
  border: 1px solid var(--glass-border);
}

.steps-list {
  display: grid;
  gap: 12px;
}

.step-item {
  display: flex;
  gap: 14px;
  align-items: flex-start;
  padding: 14px 16px;
  border-radius: 14px;
  background: rgba(0, 0, 0, 0.18);
  border: 1px solid var(--glass-border);
}

.step-num {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  flex-shrink: 0;
  display: grid;
  place-items: center;
  font-weight: 800;
  font-size: 0.8125rem;
  color: #fff;
  background: var(--gradient);
  box-shadow: 0 4px 16px rgba(139, 92, 246, 0.35);
}

.step-item p {
  margin: 0;
  line-height: 1.65;
  color: rgba(255, 255, 255, 0.88);
}

.share-card {
  text-align: center;
  padding: 28px 22px;
  background:
    radial-gradient(ellipse 120% 80% at 10% 0%, rgba(251, 191, 36, 0.18), transparent 55%),
    radial-gradient(ellipse 100% 70% at 100% 100%, rgba(236, 72, 153, 0.2), transparent 50%),
    var(--glass-bg);
  border-color: rgba(251, 191, 36, 0.12);
}

.share-pattern {
  margin-bottom: 14px;
  color: rgba(252, 211, 77, 0.75);
}

.share-card h2 {
  font-size: clamp(1.5rem, 4vw, 2.25rem);
  line-height: 1.2;
  max-width: 560px;
  margin: 0 auto 16px;
  font-weight: 700;
}

.share-footer {
  color: var(--muted);
  margin: 0;
  font-size: 0.8125rem;
  letter-spacing: 0.06em;
}

.safety-banner {
  padding: 16px 18px;
  border-radius: var(--radius-card);
  color: #fde68a;
  background:
    linear-gradient(135deg, rgba(251, 191, 36, 0.12), rgba(236, 72, 153, 0.08)),
    rgba(255, 255, 255, 0.03);
  border-color: rgba(251, 191, 36, 0.2);
  font-size: 0.875rem;
  line-height: 1.55;
}

.disclaimer-card p {
  margin: 0;
  font-size: 0.8125rem;
}

.pattern-explanation-body--fade {
  animation: explanationFadeIn 0.55s ease-out both;
}

@keyframes explanationFadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.input-mode-toggle {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 14px;
}

@media (min-width: 480px) {
  .input-mode-toggle {
    flex-direction: row;
    flex-wrap: wrap;
  }
}

.input-mode-toggle__opt {
  flex: 1;
  min-height: 44px;
  padding: 10px 16px;
  border-radius: 999px;
  border: 1px solid var(--glass-border);
  background: rgba(0, 0, 0, 0.2);
  color: var(--muted);
  font-size: 0.8125rem;
  font-weight: 600;
  cursor: pointer;
  transition:
    color 0.2s,
    border-color 0.2s,
    background 0.2s;
}

.input-mode-toggle__opt:hover {
  color: var(--text);
  border-color: rgba(139, 92, 246, 0.35);
}

.input-mode-toggle__opt--active {
  color: var(--text);
  border-color: rgba(139, 92, 246, 0.55);
  background: rgba(139, 92, 246, 0.12);
}

.reflection-history {
  max-width: 860px;
  margin: 28px auto 0;
}

.reflection-history__details {
  border-radius: var(--radius-card);
  border: 1px solid var(--glass-border);
  background: var(--glass-bg);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  box-shadow: var(--shadow-soft);
  overflow: hidden;
}

.reflection-history__summary {
  list-style: none;
  cursor: pointer;
  padding: 16px 18px;
  font-weight: 600;
  font-size: 0.9375rem;
}

.reflection-history__summary::-webkit-details-marker {
  display: none;
}

.reflection-history__summary-inner {
  display: flex;
  align-items: center;
  gap: 10px;
}

.reflection-history__chevron {
  margin-left: auto;
  flex-shrink: 0;
  transition: transform 0.25s ease;
}

.reflection-history__details[open] .reflection-history__chevron {
  transform: rotate(180deg);
}

.reflection-history__body {
  padding: 0 12px 16px;
  border-top: 1px solid var(--glass-border);
}

.reflection-history__empty {
  margin: 16px 8px;
  color: var(--muted);
  font-size: 0.875rem;
}

.reflection-history__list {
  list-style: none;
  margin: 0;
  padding: 8px 0 0;
}

.reflection-history__item {
  width: 100%;
  text-align: left;
  padding: 14px 12px;
  margin-bottom: 8px;
  border-radius: 14px;
  border: 1px solid var(--glass-border);
  background: rgba(0, 0, 0, 0.18);
  color: var(--text);
  cursor: pointer;
  display: grid;
  gap: 6px;
  transition:
    border-color 0.2s,
    background 0.2s;
}

.reflection-history__item:hover {
  border-color: rgba(139, 92, 246, 0.35);
  background: rgba(139, 92, 246, 0.08);
}

.reflection-history__date {
  font-size: 0.75rem;
  color: var(--muted);
}

.reflection-history__pattern {
  font-weight: 700;
  font-size: 0.9375rem;
}

.reflection-history__preview {
  font-size: 0.8125rem;
  color: rgba(255, 255, 255, 0.65);
  line-height: 1.45;
}

.unsent-message-card {
  background:
    radial-gradient(ellipse 100% 80% at 50% 0%, rgba(251, 191, 36, 0.14), transparent 55%),
    var(--glass-bg);
  border-color: rgba(251, 191, 36, 0.15);
}

.unsent-message-card__quote {
  margin: 0 0 14px;
  padding: 0;
  border: none;
  font-size: clamp(1.15rem, 3.5vw, 1.45rem);
  line-height: 1.65;
  font-style: italic;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.92);
}

.unsent-message-card__ready {
  margin: 0 0 16px;
  font-size: 0.8125rem;
  color: var(--muted);
}

.unsent-message-card__copy {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 18px;
  border-radius: 999px;
  border: 1px solid var(--glass-border);
  background: rgba(0, 0, 0, 0.2);
  color: var(--text);
  font-size: 0.8125rem;
  font-weight: 600;
  cursor: pointer;
  transition:
    border-color 0.2s,
    background 0.2s;
}

.unsent-message-card__copy:hover {
  border-color: rgba(139, 92, 246, 0.45);
  background: rgba(139, 92, 246, 0.12);
}

.post-result-rail {
  display: flex;
  flex-direction: column;
  gap: 14px;
  padding: 4px 0 8px;
}

.post-result-rail__buttons {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

@media (min-width: 480px) {
  .post-result-rail__buttons {
    flex-direction: row;
    flex-wrap: wrap;
  }
}

.post-result-rail__btn {
  flex: 1;
  min-height: 44px;
  min-width: 0;
  padding: 10px 14px;
  border-radius: 999px;
  border: 1px solid var(--glass-border);
  background: transparent;
  color: var(--muted);
  font-size: 0.8125rem;
  font-weight: 600;
  cursor: pointer;
  transition:
    color 0.2s,
    border-color 0.2s,
    background 0.2s;
}

.post-result-rail__btn:hover:not(:disabled) {
  color: var(--text);
  border-color: rgba(139, 92, 246, 0.45);
  background: rgba(139, 92, 246, 0.12);
}

.post-result-rail__btn:disabled {
  opacity: 0.65;
  cursor: not-allowed;
}

.post-result-rail__error {
  margin: 0;
  font-size: 0.8125rem;
  color: #fca5a5;
}

.post-result-rail__muted {
  margin: 0 0 10px;
  font-size: 0.875rem;
  color: var(--muted);
}

.post-result-rail__deeper {
  border-radius: var(--radius-card);
  border: 1px solid var(--glass-border);
  background: rgba(0, 0, 0, 0.2);
  overflow: hidden;
}

.post-result-rail__deeper-toggle {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 14px 16px;
  border: none;
  background: transparent;
  color: var(--text);
  font-size: 0.875rem;
  font-weight: 600;
  cursor: pointer;
  text-align: left;
}

.post-result-rail__deeper-toggle svg:last-child {
  margin-left: auto;
}

.post-result-rail__deeper-panel {
  padding: 0 16px 16px;
  border-top: 1px solid var(--glass-border);
}

.post-result-rail__deeper-text {
  margin: 14px 0 0;
  font-size: 0.9375rem;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.88);
}

.emotional-fingerprint {
  max-width: 860px;
  margin: 0 auto 24px;
  padding: 20px 22px;
  border-radius: var(--radius-card);
  border: 1px solid var(--glass-border);
  background: var(--glass-bg);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  box-shadow: var(--shadow-soft);
}

.emotional-fingerprint__title {
  margin: 0 0 6px;
  font-size: 1rem;
  font-weight: 700;
}

.emotional-fingerprint__subtitle {
  margin: 0 0 16px;
  font-size: 0.8125rem;
  color: var(--muted);
}

.emotional-fingerprint__pills {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.emotional-fingerprint__pill {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 8px 14px;
  border-radius: 999px;
  border: 1px solid var(--glass-border);
  background: rgba(0, 0, 0, 0.18);
  font-size: 0.8125rem;
  font-weight: 600;
}

.emotional-fingerprint__count {
  min-width: 1.5rem;
  height: 1.5rem;
  padding: 0 6px;
  border-radius: 999px;
  background: rgba(139, 92, 246, 0.25);
  color: #ddd6fe;
  font-size: 0.75rem;
  font-weight: 800;
  display: grid;
  place-items: center;
}

.share-card__actions {
  margin-top: 18px;
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 10px;
}

.share-card__save-img {
  min-height: 44px;
  padding: 10px 18px;
  border-radius: 999px;
  border: 1px solid var(--glass-border);
  background: rgba(0, 0, 0, 0.2);
  color: var(--muted);
  font-size: 0.8125rem;
  font-weight: 600;
  cursor: pointer;
  transition:
    color 0.2s,
    border-color 0.2s,
    background 0.2s;
}

.share-card__save-img:hover {
  color: var(--text);
  border-color: rgba(139, 92, 246, 0.45);
  background: rgba(139, 92, 246, 0.12);
}

.share-capture-target {
  position: fixed;
  left: -9999px;
  top: 0;
  width: 1080px;
  height: 1080px;
  padding: 48px 40px;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  background: radial-gradient(ellipse 80% 60% at 50% 20%, rgba(139, 92, 246, 0.35), transparent),
    linear-gradient(165deg, #0c0c14 0%, #080810 100%);
  border-radius: 24px;
  color: #fff;
  font-family: "Inter", system-ui, sans-serif;
}

.share-capture-target__brand {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.55);
}

.share-capture-target__dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--gradient);
}

.share-capture-target__pattern {
  margin: 0;
  font-size: 28px;
  font-weight: 800;
  line-height: 1.2;
  color: #fff;
}

.share-capture-target__insight {
  margin: 0;
  font-size: 16px;
  line-height: 1.55;
  color: rgba(255, 255, 255, 0.55);
  max-width: 36ch;
}

@media (max-width: 768px) {
  .results-page-head {
    text-align: left;
  }

  .hero-section {
    text-align: left;
  }

  .hero-badge {
    margin-left: 0;
    margin-right: auto;
  }

  .panel-tip {
    text-align: left;
  }

  .input-panel,
  .result-card,
  .share-card,
  .disclaimer-card {
    padding: 18px;
  }
}

/* —— App layout + bottom navigation (Phase 2 Step 1) —— */
.app-layout {
  min-height: 100vh;
  padding-bottom: calc(76px + env(safe-area-inset-bottom, 0px));
}

@media (max-width: 768px) {
  .topbar--with-bottom-nav {
    display: none;
  }
}

.page-placeholder {
  margin: 24px 0 0;
  color: var(--muted);
  font-size: 0.9375rem;
}

.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 6px;
  padding: 10px 14px calc(10px + env(safe-area-inset-bottom, 0px));
  border-top: 1px solid rgba(255, 255, 255, 0.06);
  background: rgba(8, 8, 16, 0.88);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
}

.bottom-nav__link {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4px;
  min-height: 52px;
  max-width: 88px;
  margin: 0 auto;
  padding: 6px 4px;
  border-radius: 14px;
  background: transparent;
  color: rgba(255, 255, 255, 0.35);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.02em;
  text-decoration: none;
  transition:
    color 0.2s ease,
    background 0.2s ease;
}

.bottom-nav__link .bottom-nav__icon {
  stroke: currentColor;
}

.bottom-nav__link--active {
  color: transparent;
  background: linear-gradient(135deg, #8b5cf6, #ec4899);
  -webkit-background-clip: text;
  background-clip: text;
}

.bottom-nav__link--active .bottom-nav__icon {
  color: transparent;
  background: linear-gradient(135deg, #8b5cf6, #ec4899);
  -webkit-background-clip: text;
  background-clip: text;
  stroke: transparent;
}

.bottom-nav__fab {
  flex: 0 0 auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2px;
  width: 56px;
  height: 56px;
  margin: 0 4px;
  margin-bottom: 2px;
  border-radius: 50%;
  border: 1px solid rgba(255, 255, 255, 0.12);
  background: var(--gradient);
  color: #fff;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  text-decoration: none;
  box-shadow: 0 10px 32px rgba(139, 92, 246, 0.35);
  transition:
    transform 0.2s ease,
    box-shadow 0.2s ease;
}

.bottom-nav__fab:hover {
  transform: scale(1.04);
  box-shadow: 0 12px 36px rgba(236, 72, 153, 0.3);
}

.bottom-nav__fab--on-home {
  box-shadow:
    0 0 0 2px rgba(255, 255, 255, 0.2),
    0 10px 32px rgba(139, 92, 246, 0.45);
}

/* —— The Gate (Home) — Phase 2 Step 2 —— */
.gate {
  position: relative;
  display: flex;
  flex-direction: column;
  min-height: min(100dvh, 100vh);
  padding-top: 12px;
  padding-bottom: 12px;
}

.gate__body {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
  position: relative;
}

.gate__backdrop {
  flex: 1;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  min-height: 0;
  cursor: default;
  outline: none;
}

.gate--arrival .gate__backdrop {
  cursor: pointer;
}

.gate--input .gate__backdrop {
  justify-content: flex-start;
  padding-top: 48px;
  cursor: default;
}

.gate__close {
  position: absolute;
  top: 8px;
  right: 8px;
  z-index: 25;
  width: 44px;
  height: 44px;
  display: grid;
  place-items: center;
  border: none;
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.04);
  color: rgba(255, 255, 255, 0.35);
  font-size: 1.5rem;
  line-height: 1;
  cursor: pointer;
  transition:
    color 0.2s,
    background 0.2s;
}

.gate__close:hover {
  color: rgba(255, 255, 255, 0.65);
  background: rgba(255, 255, 255, 0.08);
}

.gate__center {
  width: 100%;
  max-width: 560px;
  margin: 0 auto;
  padding: 0 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 28px;
}

.gate__center--input {
  align-items: stretch;
  max-width: min(560px, 100%);
  padding-top: 8px;
}

.gate-question__track {
  position: relative;
  width: 100%;
  min-height: 5.5em;
}

.gate-question__line {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  margin: 0;
  font-size: clamp(22px, 5vw, 36px);
  font-weight: 500;
  color: rgba(255, 255, 255, 0.85);
  text-align: center;
  line-height: 1.4;
  opacity: 0;
  transition: opacity 0.6s ease;
  pointer-events: none;
}

.gate-question__line--on {
  opacity: 1;
}

.gate__question-frozen {
  margin: 0;
  font-size: clamp(18px, 4vw, 26px);
  font-weight: 500;
  color: rgba(255, 255, 255, 0.85);
  text-align: center;
  line-height: 1.4;
}

.gate__start-hint {
  margin: 0;
  font-size: 13px;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.3);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  animation: subtlePulse 3s ease-in-out infinite;
}

@keyframes subtlePulse {
  0%,
  100% {
    opacity: 0.3;
  }
  50% {
    opacity: 0.7;
  }
}

.gate-input-drawer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 40;
  padding: 0 16px;
  padding-bottom: calc(76px + env(safe-area-inset-bottom, 0px) + 8px);
  max-width: 1120px;
  max-height: min(88dvh, 880px);
  margin: 0 auto;
  width: 100%;
  overflow-y: auto;
  transform: translateY(100%);
  opacity: 0;
  pointer-events: none;
  transition:
    transform 500ms cubic-bezier(0.16, 1, 0.3, 1),
    opacity 500ms cubic-bezier(0.16, 1, 0.3, 1);
}

.gate-input-drawer--open {
  transform: translateY(0);
  opacity: 1;
  pointer-events: auto;
}

.gate-input-wrapper {
  overflow-y: auto;
  max-height: calc(100dvh - 200px);
  position: sticky;
  bottom: 0;
}

.gate__vault-teaser {
  display: block;
  margin-top: auto;
  padding: 12px 16px 4px;
  text-align: center;
  font-size: 12px;
  color: var(--muted);
  text-decoration: none;
  transition: color 0.2s;
}

.gate__vault-teaser:hover {
  color: rgba(255, 255, 255, 0.65);
}

@media (min-width: 769px) {
  .gate--input .gate__backdrop {
    padding-top: 56px;
  }
}

/* —— Cinematic Results (Phase 2 Step 3) —— */
.results-cinematic.app-shell {
  max-width: none;
  width: 100%;
  padding-left: 0;
  padding-right: 0;
  padding-bottom: calc(76px + env(safe-area-inset-bottom, 0px) + 32px);
}

.results-cinematic > .safety-banner {
  margin: 12px auto 0;
  max-width: 720px;
  width: calc(100% - 48px);
}

.results-chapters {
  width: 100%;
}

.chapter {
  position: relative;
  width: 100%;
}

.chapter__inner {
  width: 100%;
  max-width: 720px;
  margin: 0 auto;
  padding: 0 24px;
}

.chapter__label {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--muted);
  margin: 0 0 16px;
}

.chapter--pattern {
  min-height: 100vh;
  min-height: 100dvh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.chapter--pattern__inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  gap: 1.25rem;
  padding: 40px 24px 100px;
  max-width: 640px;
}

.chapter--pattern__context {
  margin: 0;
  font-size: 0.875rem;
  line-height: 1.65;
  color: var(--muted);
  max-height: 28vh;
  overflow-y: auto;
  text-align: center;
}

.chapter--pattern__title {
  margin: 0;
  font-size: 52px;
  font-weight: 800;
  line-height: 1.1;
  letter-spacing: -0.02em;
  animation: chapterPatternTitleIn 1s ease forwards;
}

.chapter--pattern__title--static {
  animation: none;
  opacity: 1;
}

@keyframes chapterPatternTitleIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.chapter--pattern__confidence {
  margin: 0;
  font-size: 1.05rem;
  line-height: 1.65;
  color: rgba(255, 255, 255, 0.75);
  max-width: 560px;
  opacity: 0;
  transition: opacity 0.7s ease;
}

.chapter--pattern__confidence--on {
  opacity: 1;
}

.chapter--pattern__scroll {
  position: absolute;
  bottom: max(24px, env(safe-area-inset-bottom));
  left: 50%;
  transform: translateX(-50%);
  color: rgba(255, 255, 255, 0.28);
  opacity: 0;
  transition: opacity 0.6s ease;
  pointer-events: none;
}

.chapter--pattern__scroll--on {
  opacity: 1;
}

.chapter--explain {
  min-height: 100vh;
  min-height: 100dvh;
  display: flex;
  align-items: center;
  background: rgba(139, 92, 246, 0.06);
  padding: 56px 0;
}

.chapter--explain__inner {
  max-width: 960px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 40px;
  align-items: start;
}

.chapter--explain__body {
  margin: 0;
  font-size: 1.05rem;
  line-height: 1.75;
  color: rgba(255, 255, 255, 0.88);
}

.chapter--explain__need {
  margin: 0;
  font-size: 1.05rem;
  line-height: 1.75;
  font-style: italic;
  color: rgba(255, 255, 255, 0.82);
}

.chapter--letter {
  min-height: 100vh;
  min-height: 100dvh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.chapter--letter__inner {
  text-align: center;
  max-width: 640px;
  padding: 48px 24px;
}

.chapter--letter__label {
  margin: 0 0 24px;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--muted);
}

.chapter--letter__quote {
  margin: 0;
  padding: 0;
  border: none;
}

.chapter--letter__oq {
  display: block;
  font-size: 3rem;
  line-height: 0.6;
  color: rgba(255, 255, 255, 0.14);
  margin-bottom: 4px;
}

.chapter--letter__text {
  font-size: clamp(1.2rem, 4vw, 1.55rem);
  font-style: italic;
  font-weight: 500;
  line-height: 1.75;
  color: rgba(255, 255, 255, 0.92);
}

.chapter--letter__cq {
  font-size: 2rem;
  color: rgba(255, 255, 255, 0.14);
  vertical-align: bottom;
  margin-left: 2px;
}

.chapter--steps {
  min-height: 100vh;
  min-height: 100dvh;
  display: flex;
  align-items: center;
  padding: 72px 0;
}

.chapter--steps__inner {
  max-width: 640px;
}

.chapter-steps__list {
  display: flex;
  flex-direction: column;
  gap: 22px;
}

.chapter-step {
  display: flex;
  gap: 16px;
  align-items: flex-start;
  opacity: 0;
  transform: translateY(20px);
  transition:
    opacity 0.65s ease,
    transform 0.65s ease;
}

.chapter-step--visible {
  opacity: 1;
  transform: translateY(0);
}

.chapter-step__num {
  flex-shrink: 0;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  display: grid;
  place-items: center;
  font-weight: 800;
  font-size: 0.875rem;
  color: #fff;
  background: var(--gradient);
  box-shadow: 0 4px 16px rgba(139, 92, 246, 0.3);
}

.chapter-step__text {
  margin: 0;
  padding-top: 6px;
  line-height: 1.65;
  color: rgba(255, 255, 255, 0.88);
}

.chapter--close {
  min-height: 60vh;
  padding: 48px 0 40px;
}

.chapter--close__inner {
  max-width: 720px;
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.chapter--close__vault-link {
  text-align: center;
  font-size: 0.9375rem;
  font-weight: 600;
  color: var(--muted);
  text-decoration: none;
  transition: color 0.2s;
}

.chapter--close__vault-link:hover {
  color: rgba(255, 255, 255, 0.75);
}

.chapter--close__disclaimer {
  margin-top: 4px;
}

.chapter-progress {
  position: fixed;
  right: max(12px, env(safe-area-inset-right));
  top: 50%;
  transform: translateY(-50%);
  z-index: 90;
  display: flex;
  flex-direction: column;
  gap: 10px;
  padding: 8px 4px;
}

.chapter-progress__dot {
  width: 10px;
  height: 10px;
  padding: 0;
  border: none;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
  cursor: pointer;
  transition:
    transform 0.25s ease,
    box-shadow 0.25s ease,
    background 0.25s ease;
}

.chapter-progress__dot:hover {
  transform: scale(1.12);
  background: rgba(255, 255, 255, 0.22);
}

.chapter-progress__dot--active {
  background: var(--gradient);
  box-shadow: 0 0 12px rgba(236, 72, 153, 0.35);
}

@media (max-width: 768px) {
  .chapter--explain__inner {
    grid-template-columns: 1fr;
    gap: 28px;
  }

  .chapter--pattern__title {
    font-size: clamp(30px, 9vw, 52px);
  }

  .chapter-progress {
    right: 8px;
    gap: 8px;
  }

  .chapter-progress__dot {
    width: 8px;
    height: 8px;
  }
}

@media (prefers-reduced-motion: reduce) {
  .chapter--pattern__title {
    animation: none;
    opacity: 1;
  }
  
  .loading-breather {
    animation: none;
  }
  
  .chapter--pattern__confidence {
    opacity: 1;
    transition: none;
  }

  .chapter--pattern__scroll {
    opacity: 1;
    transition: none;
  }

  .chapter-step {
    opacity: 1;
    transform: none;
    transition: none;
  }
}

/* Page Transitions */
.page-transition {
  opacity: 0;
  animation: pageEnter 200ms ease-out forwards;
}

@keyframes pageEnter {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

/* Mobile Safe Areas */
.bottom-nav {
  padding-bottom: calc(10px + env(safe-area-inset-bottom, 0px));
}

.gate,
.results-cinematic,
.vault-page,
.profile-page {
  padding-bottom: calc(80px + env(safe-area-inset-bottom, 0px));
}

/* Final prefers-reduced-motion audit */
@media (prefers-reduced-motion: reduce) {
  * {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
}

/* Emotional Atmosphere System */
html {
  transition: 
    --atm-orb1 1200ms ease,
    --atm-orb2 1200ms ease;
}

.orb-1, .orb-2 {
  transition: background 1200ms ease;
}

.input-panel,
.result-card,
.share-card,
.disclaimer-card,
.safety-banner {
  transition: background 800ms ease;
}

[data-atmosphere="rejection"] {
  --atm-orb1: rgba(59, 130, 246, 0.12);
  --atm-orb2: rgba(99, 102, 241, 0.08);
  --atm-accent: #3b82f6;
  --atm-card-bg: rgba(59, 130, 246, 0.04);
}

[data-atmosphere="attachment"] {
  --atm-orb1: rgba(245, 158, 11, 0.15);
  --atm-orb2: rgba(239, 68, 68, 0.1);
  --atm-accent: #f59e0b;
  --atm-card-bg: rgba(245, 158, 11, 0.05);
}

[data-atmosphere="suppression"] {
  --atm-orb1: rgba(30, 30, 40, 0.8);
  --atm-orb2: rgba(20, 20, 30, 0.9);
  --atm-accent: #6b7280;
  --atm-card-bg: rgba(255, 255, 255, 0.02);
}

[data-atmosphere="cognitive"] {
  --atm-orb1: rgba(139, 92, 246, 0.2);
  --atm-orb2: rgba(236, 72, 153, 0.15);
  --atm-accent: #8b5cf6;
  --atm-card-bg: rgba(139, 92, 246, 0.06);
}

[data-atmosphere="validation"] {
  --atm-orb1: rgba(236, 72, 153, 0.18);
  --atm-orb2: rgba(251, 191, 36, 0.1);
  --atm-accent: #ec4899;
  --atm-card-bg: rgba(236, 72, 153, 0.05);
}

[data-atmosphere="avoidant"] {
  --atm-orb1: rgba(75, 85, 99, 0.15);
  --atm-orb2: rgba(55, 65, 81, 0.1);
  --atm-accent: #9ca3af;
  --atm-card-bg: rgba(255, 255, 255, 0.02);
}

[data-atmosphere="default"] {
  --atm-orb1: rgba(139, 92, 246, 0.15);
  --atm-orb2: rgba(236, 72, 153, 0.1);
  --atm-accent: #8b5cf6;
  --atm-card-bg: rgba(255, 255, 255, 0.04);
}

export function getAtmosphere(patternName) {
  const map = {
    "Anxious Attachment Activation": "attachment",
    "Avoidant Attachment Defense": "avoidant",
    "Fearful Avoidant Conflict": "attachment",
    "Abandonment Schema": "attachment",
    "Emotional Deprivation Schema": "suppression",
    "Mistrust and Abuse Schema": "avoidant",
    "Catastrophizing Spiral": "cognitive",
    "All-or-Nothing Processing": "cognitive",
    "Mind Reading Trap": "cognitive",
    "Personalization Bias": "cognitive",
    "Emotional Reasoning": "cognitive",
    "Should Statement Tyranny": "cognitive",
    "Cognitive Distortion Loop": "cognitive",
    "Rumination Cycle": "cognitive",
    "Confirmation Bias Trap": "cognitive",
    "Emotional Suppression": "suppression",
    "Emotional Numbing": "suppression",
    "Affect Dysregulation": "attachment",
    "Alexithymia Response": "suppression",
    "Emotional Flooding": "attachment",
    "Avoidant Defense Mechanism": "avoidant",
    "Rationalization Shield": "avoidant",
    "Projection Pattern": "cognitive",
    "Dissociative Avoidance": "suppression",
    "Reaction Formation": "cognitive",
    "Internalized Self-Doubt": "cognitive",
    "Impostor Schema": "cognitive",
    "Core Wound Activation": "attachment",
    "Shame Spiral": "suppression",
    "Defectiveness Schema": "suppression",
    "Rejection Anticipation": "rejection",
    "Validation Hunger": "validation",
    "Fawn Response": "validation",
    "People Pleasing Compulsion": "validation",
    "Enmeshment Pattern": "attachment",
    "Fear of Vulnerability": "avoidant",
    "Hypervigilance State": "attachment",
    "Somatic Anxiety Response": "attachment",
    "Time Perception Distortion": "suppression",
    "Depersonalization Response": "suppression",
    "Hyperarousal Pattern": "attachment",
    "Freeze Response": "suppression",
    "Complicated Grief Response": "suppression",
    "Anticipatory Loss": "attachment",
    "Ambiguous Loss Processing": "suppression",
    "Trauma Response Activation": "attachment",
    "Hypervigilance After Betrayal": "avoidant",
    "Unresolved Emotional Imprint": "attachment",
    "Identity Diffusion": "cognitive",
    "Moral Perfectionism": "cognitive",
    "Existential Emptiness": "suppression",
  };
  return map[patternName] || "default";
}
